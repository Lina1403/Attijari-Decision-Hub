VITE_API_BASE_URL=http://localhost:5002/api
VITE_ML_API_BASE_URL=http://localhost:5001/api

# Rapport quotidien par e-mail. Activez seulement apres avoir configure SMTP.
DAILY_REPORT_ENABLED=false
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0

# Dashboard AI Summary API / Groq
GROQ_API_KEY=<your_groq_api_key>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=20000
GROQ_MAX_COMPLETION_TOKENS=650
DASHBOARD_AI_CACHE_TTL_MS=300000
DASHBOARD_AI_ALLOW_FIXTURE_FALLBACK=false

# Power BI SDK embed requis pour la lecture live des dashboards par l IA
VITE_POWERBI_EMBED_URL=
VITE_POWERBI_ACCESS_TOKEN=

# Power BI Embedded securise via le backend local
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
POWERBI_AUTHORITY_BASE_URL=https://login.microsoftonline.com
POWERBI_API_BASE_URL=https://api.powerbi.com/v1.0/myorg
POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
POWERBI_TIMEOUT_MS=15000
POWERBI_EMBED_TOKEN_LIFETIME_MINUTES=60

